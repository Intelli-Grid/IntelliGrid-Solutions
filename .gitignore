# =============================================================================
# IntelliGrid — .gitignore
# Private production repository. Only source code and deployment configs.
# =============================================================================

# -----------------------------------------------------------------------------
# ENVIRONMENT & SECRETS — NEVER COMMIT
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
*.env
config/secrets.*
**/credentials/
**/secrets/
**/*_credentials.json
**/*_keys.json

# -----------------------------------------------------------------------------
# DEPENDENCIES
# -----------------------------------------------------------------------------
node_modules/
.pnp
.pnp.js

# -----------------------------------------------------------------------------
# BUILD ARTIFACTS
# -----------------------------------------------------------------------------
dist/
build/
out/
.next/
.cache/
.parcel-cache/

# -----------------------------------------------------------------------------
# LOGS & TEMP FILES
# -----------------------------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
tmp/
temp/
*.tmp
*.temp

# -----------------------------------------------------------------------------
# OS & EDITOR FILES
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# -----------------------------------------------------------------------------
# DOCUMENTATION, GUIDES & INTERNAL NOTES (local only)
# -----------------------------------------------------------------------------
# All markdown files except README.md
*.md
!README.md

# Data files
*.csv
*.rtf
*.txt
!**/.env.example.txt

# Reports
*.report.html
*.report.json

# Ad-hoc scripts
*.ps1
test-*.js
test-*.sh

# Any dev session notes or guides
docs/
guides/
notes/

# apps/admin is a live Vercel project — keep tracked
# Only exclude its local build artifacts and secrets
apps/admin/node_modules/
apps/admin/dist/
apps/admin/.env
apps/admin/.env.*
apps/admin/.env.production

# -----------------------------------------------------------------------------
# CI & DEPLOYMENT TOOLS (local)
# -----------------------------------------------------------------------------
.gemini/
.agent/

# Vercel local config (auto-generated, not needed in repo)
.vercel
