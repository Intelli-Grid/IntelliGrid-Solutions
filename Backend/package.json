{
    "name": "intelligrid-backend",
    "version": "1.0.0",
    "description": "IntelliGrid Backend API Server",
    "main": "src/app.js",
    "type": "module",
    "engines": {
        "node": ">=20.18.0",
        "npm": ">=10.0.0"
    },
    "scripts": {
        "start": "node --import ./src/instrument.js src/server.js",
        "dev": "nodemon src/server.js",
        "import-tools": "node scripts/importTools.js",
        "sync-algolia": "node scripts/syncAlgolia.js",
        "validate:links": "node scripts/validateLinks.js",
        "validate:links:all": "node scripts/validateLinks.js --all",
        "fix:toolcounts": "node scripts/fix-category-toolcount.js",
        "run:discovery": "node scripts/runDiscovery.js",
        "run:discovery:week": "node scripts/runDiscovery.js --days 7",
        "generate:seo-meta": "node scripts/generateSEOMeta.js",
        "generate:seo-meta:test": "node scripts/generateSEOMeta.js --limit 10 --dry-run",
        "generate:seo-meta:force": "node scripts/generateSEOMeta.js --force",
        "backup": "node scripts/backupMongoDB.js",
        "restore": "node scripts/restoreMongoDB.js",
        "test:webhooks": "node scripts/testWebhooks.js",
        "test:emails": "node scripts/testEmails.js",
        "health:check": "node scripts/healthCheck.js",
        "generate-sitemap": "node scripts/generateSitemap.js",
        "verify:launch": "node scripts/verifyLaunchReadiness.js",
        "promote-admin": "node scripts/promoteAdmin.js",
        "migrate:up": "migrate-mongo up",
        "migrate:down": "migrate-mongo down",
        "migrate:status": "migrate-mongo status",
        "seed:flags": "node src/scripts/seedFeatureFlags.js",
        "import:competitors": "node src/scripts/competitorImport.js",
        "dedup:tools": "node src/scripts/deduplicateTools.js",
        "enrich:bulk": "node src/scripts/bulkEnrich.js",
        "crawl:futurepedia": "python src/scripts/python/crawl_futurepedia.py",
        "crawl:aixploria": "python src/scripts/python/crawl_aixploria.py",
        "crawl:futuretools": "python src/scripts/python/crawl_futuretools.py",
        "enrich:import": "node src/scripts/importEnrichmentData.js",
        "enrich:cron:run": "node -e \"import('./src/jobs/enrichmentCron.js').then(m => m.runEnrichmentCheck ? m.runEnrichmentCheck() : console.log('No export found'))\"",
        "test": "cross-env NODE_OPTIONS=--experimental-vm-modules jest"
    },
    "keywords": [
        "ai",
        "tools",
        "directory",
        "api"
    ],
    "author": "IntelliGrid",
    "license": "PROPRIETARY",
    "dependencies": {
        "@clerk/express": "^1.7.72",
        "@getbrevo/brevo": "^3.0.1",
        "@paypal/paypal-server-sdk": "^2.2.0",
        "@sentry/node": "^9.47.1",
        "@sentry/profiling-node": "^9.47.1",
        "@sparticuz/chromium": "^143.0.4",
        "algoliasearch": "^4.22.0",
        "axios": "^1.13.4",
        "bcryptjs": "^2.4.3",
        "bullmq": "^5.70.1",
        "cheerio": "^1.2.0",
        "cloudinary": "^2.9.0",
        "compression": "^1.7.4",
        "cors": "^2.8.5",
        "csv-parse": "^5.6.0",
        "csv-parser": "^3.0.0",
        "dotenv": "^16.3.1",
        "express": "^4.18.2",
        "express-mongo-sanitize": "^2.2.0",
        "express-rate-limit": "^7.1.5",
        "express-validator": "^7.0.1",
        "groq-sdk": "^0.37.0",
        "helmet": "^7.1.0",
        "jsonwebtoken": "^9.0.2",
        "mongodb": "^6.3.0",
        "mongoose": "^8.0.3",
        "morgan": "^1.10.0",
        "nanoid": "^3.3.7",
        "node-cron": "^4.2.1",
        "puppeteer": "^24.37.2",
        "puppeteer-core": "^24.37.5",
        "redis": "^4.6.12",
        "sib-api-v3-sdk": "^8.5.0",
        "slugify": "^1.6.6",
        "string-similarity": "^4.0.4",
        "svix": "^1.85.0",
        "telegraf": "^4.16.3"
    },
    "devDependencies": {
        "cross-env": "^10.1.0",
        "jest": "^30.2.0",
        "jwt-decode": "^4.0.0",
        "localtunnel": "^2.0.2",
        "migrate-mongo": "^14.0.7",
        "nodemon": "^3.0.2",
        "supertest": "^7.2.2"
    }
}
