# Server Configuration
NODE_ENV=development
PORT=10000

# Database
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/intelligrid?retryWrites=true&w=majority

# Authentication - Clerk
CLERK_SECRET_KEY=your_clerk_secret_key_here
CLERK_PUBLISHABLE_KEY=pk_live_your_key_here
CLERK_WEBHOOK_SECRET=whsec_your_signing_secret_here

# Payment Gateways - PayPal
PAYPAL_MODE=live
PAYPAL_CLIENT_ID=your_paypal_client_id_here
PAYPAL_CLIENT_SECRET=your_paypal_client_secret_here
PAYPAL_WEBHOOK_ID=your_webhook_id_here
# PayPal Billing Plan IDs (from PayPal Dashboard → Products & Plans → Plan IDs)
# These start with P-, NOT PROD- (PROD- is the product ID, not the billing plan)
PAYPAL_PLAN_PRO_MONTHLY=P-your_plan_id_here
PAYPAL_PLAN_PRO_YEARLY=P-your_plan_id_here
PAYPAL_PLAN_ENTERPRISE_MONTHLY=P-your_plan_id_here
PAYPAL_PLAN_ENTERPRISE_YEARLY=P-your_plan_id_here

# Payment Gateways - Cashfree
CASHFREE_APP_ID=your_cashfree_app_id_here
CASHFREE_SECRET_KEY=your_cashfree_secret_key_here
CASHFREE_ENV=PROD

# Search - Algolia
ALGOLIA_APP_ID=your_algolia_app_id_here
ALGOLIA_ADMIN_KEY=your_algolia_admin_key_here
ALGOLIA_INDEX_NAME=intelligrid_tools

# Caching - Redis
REDIS_URL=redis://localhost:6379

# Email - Brevo
BREVO_API_KEY=your_brevo_api_key_here
BREVO_SENDER_EMAIL=support@intelligrid.online
BREVO_SENDER_NAME=IntelliGrid

# Monitoring - Sentry
SENTRY_DSN=your_sentry_dsn_here

# Frontend URL (CORS)
FRONTEND_URL=http://localhost:5173

# App Configuration
APP_NAME=IntelliGrid
APP_URL=https://intelligrid.online
BACKEND_URL=https://api.intelligrid.online

# JWT Secret (for additional auth if needed)
JWT_SECRET=your_jwt_secret_key_here_change_in_production

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=300

# Crawler (keep false in production unless explicitly running crawls)
CRAWLER_ENABLED=false

# Telegram (optional)
TELEGRAM_BOT_TOKEN=your_bot_token_here
OWNER_TELEGRAM_ID=your_telegram_user_id_here
COMMUNITY_BOT_TOKEN=your_community_bot_token_here
COMMUNITY_CHANNEL_ID=-1001234567890
